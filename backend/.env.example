# Google Drive API Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_FOLDER_ID=

# Server port (DigitalOcean App Platform injects this automatically)
# Local dev falls back to 5000 if not set
PORT=

# CORS Allowed Origins (comma-separated)
# Defaults to localhost + staging + production if not set
# Example: http://localhost:5173,https://yourdomain.com
CORS_ALLOWED_ORIGINS=

# Firebase Admin Service Account (Base64-encoded JSON)
# Required for automatic Firestore backups.
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key"
# 3. Base64-encode the downloaded JSON file:
#    Linux/Mac: base64 -i serviceAccountKey.json | pbcopy
#    Windows (PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json")) | Set-Clipboard
# 4. Paste the result here as a single-line string
FIREBASE_SERVICE_ACCOUNT=
