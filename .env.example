# Frontend Environment Variables

# Development-only: override idle timeout durations (values in milliseconds)
# VITE_IDLE_WARNING_MS=5000    # Time until warning modal appears (default: 9 min)
# VITE_IDLE_LOGOUT_MS=5000     # Time from warning to auto-logout (default: 1 min)

# Development-only: override concurrent agency user limit
# VITE_MAX_AGENCY_USERS=2      # Max agency users allowed at once (default: 25)
